class BtApp(App):
    # (ALL YOUR EXISTING CODE REMAINS EXACTLY SAME)

    @work(thread=True)
    def _do_pair(self, mac, name):
        self.call_from_thread(self._status, f"[yellow]pairing {name}...[/yellow]")

        ok = do_pair(
            mac,
            status_callback=lambda msg: self.call_from_thread(self._status, msg)
        )

        if ok:
            do_trust(mac)
            do_connect(mac)
            notify("Paired", f"Paired and connected: {name}")

            self.call_from_thread(self._status, f"[green]◉  paired: {name}[/green]")

            self._scan_mode = False
            devs = load_devices()
            self._devices = devs
            self._hsc = hsc_battery()

            self.call_from_thread(self._rebuild_list)
            self.call_from_thread(self._refresh_header)
        else:
            self.call_from_thread(self._status,
                f"[red]✗  pairing failed — is {name} in pairing mode?[/red]")

