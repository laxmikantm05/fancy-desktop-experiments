# ── 🔥 FIXED PAIRING FUNCTION ──

def do_pair(mac, status_callback=None):
    try:
        child = pexpect.spawn("bluetoothctl", encoding="utf-8", timeout=60)

        # Setup agent
        child.sendline("agent KeyboardDisplay")
        child.sendline("default-agent")

        # Start pairing
        child.sendline(f"pair {mac}")

        while True:
            i = child.expect([
                r"Confirm passkey (\d+)",
                r"Request confirmation",
                r"Enter PIN code:",
                r"Pairing successful",
                r"Failed",
                pexpect.EOF,
                pexpect.TIMEOUT
            ])

            # Show PIN
            if i == 0:
                pin = child.match.group(1)
                if status_callback:
                    status_callback(f"[bold cyan]PIN: {pin}[/bold cyan] — confirm on device")
                child.sendline("yes")

            # Just confirm
            elif i == 1:
                if status_callback:
                    status_callback("[cyan]Confirm pairing on device[/cyan]")
                child.sendline("yes")

            # PIN input required
            elif i == 2:
                if status_callback:
                    status_callback("[yellow]Enter PIN (using 0000)[/yellow]")
                child.sendline("0000")

            # Success
            elif i == 3:
                if status_callback:
                    status_callback("[green]Pairing successful[/green]")
                return True

            # Failure
            elif i == 4:
                return False

            else:
                return False

    except Exception:
        return False

