"""

    BINDINGS = [
        Binding("r",      "refresh",      "[R] Refresh"),
        Binding("s",      "scan",         "[S] Scan"),
        Binding("p",      "audio_profile","[P] Profile"),
        Binding("n",      "rename",       "[N] Rename"),
        Binding("u",      "trust_toggle", "[U] Trust"),
        Binding("x",      "remove",       "[X] Remove"),
        Binding("t",      "toggle",       "[T] Toggle BT"),
        Binding("q",      "quit",         "[Q] Quit"),
        Binding("escape", "back_or_quit", "",   show=False),
        Binding("enter",  "connect",      "[Enter] Connect"),
    ]

    _devices   = []
    _scan_list = []
    _scan_mode = False
    _hsc       = None

    def compose(self):
        yield Static("", id="header")
        with Horizontal(id="body"):
            with Vertical(id="left-panel"):
                yield Label("  󰂯  DEVICES", classes="panel-title", id="dev-title")
                yield ListView(id="device-list")
            with Vertical(id="right-panel"):
                yield Label("  DETAILS", classes="panel-title")
                yield Static("", id="details")
        yield Static("", id="statusbar")
        yield Static("  [Enter] Connect   [S] Scan   [P] Profile   [N] Rename   [U] Trust   [X] Remove   [T] Toggle   [R] Refresh   [Q] Quit", id="controls-bar")


    def on_mount(self):
        self._refresh_header()
        self._set_details(None)
        self.query_one("#device-list").focus()
        self.action_refresh()
        self.set_interval(CFG["bluetooth"]["refresh_interval"], self.action_refresh)
        self.set_interval(CFG["bluetooth"]["header_interval"],  self._refresh_header)

    def _refresh_header(self):
        on    = bt_powered()
        flg   = "[green]BT ON[/green]" if on else "[red]BT OFF[/red]"
        t     = datetime.datetime.now().strftime("%H:%M:%S")
        conn  = [d for d in self._devices if d.get("connected")]
        names = ("  [#ff2d5a]◉[/#ff2d5a] " + "   [#ff2d5a]◉[/#ff2d5a] ".join(
            f"[green]{d['name']}[/green]" for d in conn)
            ) if conn else "  [dim]○  no devices connected[/dim]"
        hsc_str = ""
        if self._hsc:
            parts = []
            if "left"  in self._hsc: parts.append(f"L {self._hsc['left']}%")
            if "right" in self._hsc: parts.append(f"R {self._hsc['right']}%")
            if "case"  in self._hsc: parts.append(f"Case {self._hsc['case']}%")
            if "level" in self._hsc: parts.append(f"Batt {self._hsc['level']}%")
            if parts: hsc_str = "  [dim]·[/dim]  [#ff2d5a]󰋋 " + "  ·  ".join(parts) + "[/#ff2d5a]"
        self.query_one("#header", Static).update(
            f"  [bold #ff2d5a]󰂯  btmenu[/bold #ff2d5a]{names}{hsc_str}   [dim]{t}[/dim]   {flg}"
        )

    def _current_list(self):
        return self._scan_list if self._scan_mode else self._devices

    def _set_details(self, dev):
        d = self.query_one("#details", Static)
        if dev is None:
            d.update("\n  [dim]select a device[/dim]")
            return
        icon    = type_icon(dev["type"])
        conn    = dev.get("connected", False)
        paired  = dev.get("paired", False)
        trusted = dev.get("trusted", False)
        lines   = [
            "", f"  [bold #ff2d5a]{dev['name']}[/bold #ff2d5a]", "",
            f"  [dim]MAC       [/dim] [dim]{dev['mac']}[/dim]",
            f"  [dim]Type      [/dim] {icon}  {dev['type']}",
            f"  [dim]Paired    [/dim] {'[green]yes[/green]' if paired else '[dim]no[/dim]'}",
            f"  [dim]Trusted   [/dim] {'[green]yes[/green]  [dim](auto-connect on)[/dim]' if trusted else '[dim]no[/dim]  (auto-connect off)'}",
            f"  [dim]Status    [/dim] {'[green]◉  connected[/green]' if conn else '[dim]○  disconnected[/dim]'}",
            "",
            f"  [dim]Battery   [/dim] {batt_bar(dev.get('battery'))}",
        ]
        if self._hsc:
            lines += ["", "  [dim]─── earbuds ────────────────[/dim]"]
            if "left"  in self._hsc: lines.append(f"  [dim]Left      [/dim] {batt_bar(self._hsc['left'])}")
            if "right" in self._hsc: lines.append(f"  [dim]Right     [/dim] {batt_bar(self._hsc['right'])}")
            if "case"  in self._hsc: lines.append(f"  [dim]Case      [/dim] {batt_bar(self._hsc['case'])}")
        lines += ["", "  [dim]──────────────────[/dim]", ""]
        if self._scan_mode:
            lines += ["  [dim][Enter][/dim]  pair this device",
                      "  [dim]make sure device is in pairing mode[/dim]"]
        elif conn:
            lines += ["  [dim][Enter][/dim]  disconnect",
                      "  [dim][P][/dim]  switch audio profile",
                      "  [dim][N][/dim]  rename",
                      "  [dim][U][/dim]  " + ("untrust (disable auto-connect)" if trusted else "trust (enable auto-connect)"),
                      "  [dim][X][/dim]  remove / unpair"]
        elif paired:
            lines += ["  [dim][Enter][/dim]  connect",
                      "  [dim][N][/dim]  rename",
                      "  [dim][U][/dim]  " + ("untrust" if trusted else "trust"),
                      "  [dim][X][/dim]  remove / unpair"]
        else:
            lines += ["  [dim][Enter][/dim]  pair and connect"]
        d.update("\n".join(lines))

    def _rebuild_list(self):
        lv   = self.query_one("#device-list", ListView)
        devs = self._current_list()
        lv.clear()
        label = f"  󰂲  NEARBY ({len(devs)})" if self._scan_mode else f"  󰂯  DEVICES ({len(devs)})"
        self.query_one("#dev-title", Label).update(label)
        for dev in devs:
            icon     = type_icon(dev["type"])
            batt_str = f"  [dim]{dev['battery']}%[/dim]" if dev.get("battery") is not None else ""
            trust_str = "  [dim]★[/dim]" if dev.get("trusted") else ""
            if dev.get("connected"):
                row = f"  {icon}  [green]{dev['name']}[/green]{batt_str}{trust_str}  [green]◉[/green]"
            else:
                row = f"  {icon}  {dev['name']}{batt_str}{trust_str}"
            lv.append(ListItem(Label(row, markup=True)))

    def _status(self, msg):
        self.query_one("#statusbar", Static).update(f"  {msg}")

    # ── actions ──

    @work(thread=True)
    def action_refresh(self):
        if self._scan_mode: return
        self.call_from_thread(self._status, "[yellow]⠿  loading...[/yellow]")
        try:
            devs        = load_devices()
            self._devices = devs
            self._hsc   = hsc_battery()
            self.call_from_thread(self._rebuild_list)
            self.call_from_thread(self._refresh_header)
            self.call_from_thread(self._status,
                f"[green]✓  {len(devs)} device{'s' if len(devs) != 1 else ''}[/green]")
        except Exception as e:
            self.call_from_thread(self._status, f"[red]✗  {e}[/red]")

    @work(thread=True)
    def action_scan(self):
        self._scan_mode = True
        self.call_from_thread(self._rebuild_list)
        self.call_from_thread(self._status, "[cyan]⠿  scanning 10s — put device in pairing mode...[/cyan]")
        try:
            found = scan_nearby(10)
            self._scan_list = found
            self.call_from_thread(self._rebuild_list)
            self.call_from_thread(self._status,
                f"[green]✓  {len(found)} nearby  [dim]([Enter] pair, [Esc] back)[/dim][/green]")
        except Exception as e:
            self.call_from_thread(self._status, f"[red]✗  {e}[/red]")

    def action_connect(self):
        lv   = self.query_one("#device-list", ListView)
        idx  = lv.index
        devs = self._current_list()
        if idx is None or idx >= len(devs): return
        dev  = devs[idx]
        if self._scan_mode:
            self._do_pair(dev["mac"], dev["name"])
        elif dev["connected"]:
            self._do_disconnect(dev["mac"], dev["name"])
        else:
            self._do_connect(dev["mac"], dev["name"])

    @work(thread=True)
    def _do_connect(self, mac, name):
        self.call_from_thread(self._status, f"[yellow]connecting to {name}...[/yellow]")
        ok = do_connect(mac)
        if ok:
            notify("Connected", f"Connected to {name}")
            self.call_from_thread(self._status, f"[green]◉  connected: {name}[/green]")
        else:
            self.call_from_thread(self._status, f"[red]✗  failed: {name}[/red]")
        devs = load_devices()
        self._devices = devs
        self._hsc = hsc_battery()
        self.call_from_thread(self._rebuild_list)
        self.call_from_thread(self._refresh_header)

    @work(thread=True)
    def _do_disconnect(self, mac, name):
        do_disconnect(mac)
        notify("Disconnected", f"Disconnected from {name}", "low")
        self.call_from_thread(self._status, f"[dim]○  disconnected: {name}[/dim]")
        devs = load_devices()
        self._devices = devs
        self.call_from_thread(self._rebuild_list)
        self.call_from_thread(self._refresh_header)

    @work(thread=True)
    def _do_pair(self, mac, name):
        self.call_from_thread(self._status, f"[yellow]pairing {name}...[/yellow]")
        ok = do_pair(mac)
        if ok:
            do_trust(mac)
            do_connect(mac)
            notify("Paired", f"Paired and connected: {name}")
            self.call_from_thread(self._status, f"[green]◉  paired: {name}[/green]")
            self._scan_mode = False
            devs = load_devices()
            self._devices = devs
            self._hsc = hsc_battery()
            self.call_from_thread(self._rebuild_list)
            self.call_from_thread(self._refresh_header)
        else:
            self.call_from_thread(self._status,
                f"[red]✗  pairing failed — is {name} in pairing mode?[/red]")

    def action_audio_profile(self):
        if self._scan_mode: return
        lv   = self.query_one("#device-list", ListView)
        idx  = lv.index
        devs = self._current_list()
        if idx is None or idx >= len(devs): return
        dev  = devs[idx]
        profiles, active, card = get_audio_profiles(dev["mac"])
        if not profiles:
            self._status("[yellow]no audio profiles found — is pactl installed?[/yellow]")
            return
        def handle(profile):
            if profile is None: return
            self._switch_profile(card, profile)
        self.push_screen(AudioProfileModal(profiles, active), handle)

    @work(thread=True)
    def _switch_profile(self, card, profile):
        ok = set_audio_profile(card, profile)
        color = "green" if ok else "red"
        msg   = f"profile → {profile}" if ok else f"failed to switch to {profile}"
        self.call_from_thread(self._status, f"[{color}]{msg}[/{color}]")

    def action_rename(self):
        if self._scan_mode: return
        lv   = self.query_one("#device-list", ListView)
        idx  = lv.index
        devs = self._current_list()
        if idx is None or idx >= len(devs): return
        dev  = devs[idx]
        def handle(new_name):
            if new_name and new_name != dev["name"]:
                do_rename(dev["mac"], new_name)
                self._status(f"[green]renamed to {new_name}[/green]")
                self._devices = load_devices()
                self.call_from_thread(self._rebuild_list)
        self.push_screen(RenameModal(dev), handle)

    @work(thread=True)
    def action_trust_toggle(self):
        if self._scan_mode: return
        lv   = self.query_one("#device-list", ListView)
        idx  = lv.index
        devs = self._current_list()
        if idx is None or idx >= len(devs): return
        dev  = devs[idx]
        if dev.get("trusted"):
            do_untrust(dev["mac"])
            self.call_from_thread(self._status,
                f"[yellow]untrusted {dev['name']} — auto-connect off[/yellow]")
        else:
            do_trust(dev["mac"])
            self.call_from_thread(self._status,
                f"[green]trusted {dev['name']} — auto-connect on[/green]")
        devs = load_devices()
        self._devices = devs
        self.call_from_thread(self._rebuild_list)

    @work(thread=True)
    def action_remove(self):
        if self._scan_mode: return
        lv   = self.query_one("#device-list", ListView)
        idx  = lv.index
        devs = self._current_list()
        if idx is None or idx >= len(devs): return
        dev  = devs[idx]
        do_remove(dev["mac"])
        self.call_from_thread(self._status, f"[dim]removed {dev['name']}[/dim]")
        devs = load_devices()
        self._devices = devs
        self.call_from_thread(self._rebuild_list)

    @work(thread=True)
    def action_toggle(self):
        toggle_bt()
        time.sleep(0.3)
        on    = bt_powered()
        color = "green" if on else "yellow"
        state = "enabled" if on else "disabled"
        self.call_from_thread(self._status, f"[{color}]bluetooth {state}[/{color}]")
        self.call_from_thread(self._refresh_header)

    def action_back_or_quit(self):
        if self._scan_mode:
            self._scan_mode = False
            self._rebuild_list()
            self._status("[dim]back to paired devices[/dim]")
        else:
            self.exit()

    def action_quit(self): self.exit()

    @on(ListView.Selected)
    def on_dev_selected(self, e): self.action_connect()

    @on(ListView.Highlighted)
    def on_dev_highlighted(self, e):
        idx  = e.list_view.index
        devs = self._current_list()
        if idx is not None and idx < len(devs):
            self._set_details(devs[idx])
        else:
            self._set_details(None)


if __name__ == "__main__":
    BtApp().run()
