#!/usr/bin/env python3
"""
CYBERPUNK BTMENU
install : sudo cp btmenu /usr/local/bin/ && sudo chmod +x /usr/local/bin/btmenu
deps    : pip install textual --break-system-packages
optional: headsetcontrol (AirPods L/R/Case battery), pactl (audio profiles)
"""

import sys
if "--help" in sys.argv or "-h" in sys.argv:
    print("""btmenu — cyberpunk Bluetooth manager

keybinds:
  [Enter]   connect / disconnect selected device
  [S]       scan for new nearby devices
  [P]       switch audio profile (headphones/headset)
  [N]       rename device
  [U]       toggle trust (auto-connect) on/off
  [X]       remove / unpair device
  [T]       toggle Bluetooth on/off
  [R]       refresh device list
  [Esc]     back from scan mode / quit
  [Q]       quit

config: ~/.config/fancy-desktop/config.toml
""")
    sys.exit(0)

import subprocess, time, os, re, json, pathlib, datetime
from textual.app        import App, ComposeResult
from textual.widgets    import (ListView, ListItem, Label, Static,
                                Input, Button, Footer)
from textual.containers import Horizontal, Vertical, Container
from textual.screen     import ModalScreen
from textual.binding    import Binding
from textual            import work, on

# ── config ───────────────────────────────────────────────────────

def load_config():
    cfg = {"bluetooth": {"refresh_interval": 5, "header_interval": 2}}
    p   = pathlib.Path.home() / ".config" / "fancy-desktop" / "config.toml"
    if not p.exists(): return cfg
    try:
        import tomllib
        with open(p, "rb") as f:
            data = tomllib.load(f)
        cfg["bluetooth"].update(data.get("bluetooth", {}))
    except Exception:
        pass
    return cfg

CFG = load_config()

# ── bluetooth helpers ─────────────────────────────────────────────

def run(cmd, timeout=12):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip(), r.returncode
    except Exception:
        return "", 1

def notify(title, body, urgency="normal"):
    try:
        subprocess.Popen(["notify-send", "-u", urgency, "-a", "btmenu", title, body],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def bt_powered():
    out, _ = run(["bluetoothctl", "show"])
    for line in out.splitlines():
        if "Powered:" in line:
            return "yes" in line.lower()
    return False

def toggle_bt():
    run(["bluetoothctl", "power", "off" if bt_powered() else "on"])

def get_devices():
    out, _ = run(["bluetoothctl", "devices"])
    devs = []
    for line in out.splitlines():
        p = line.strip().split(" ", 2)
        if len(p) >= 3 and p[0] == "Device":
            devs.append({"mac": p[1], "name": p[2],
                         "connected": False, "paired": True,
                         "trusted": False, "battery": None, "type": "unknown"})
    return devs

def enrich(dev):
    out, _ = run(["bluetoothctl", "info", dev["mac"]])
    for line in out.splitlines():
        s = line.strip()
        if s.startswith("Connected:"): dev["connected"] = "yes" in s.lower()
        elif s.startswith("Paired:"):  dev["paired"]    = "yes" in s.lower()
        elif s.startswith("Trusted:"): dev["trusted"]   = "yes" in s.lower()
        elif s.startswith("Icon:"):    dev["type"]      = s.split(":", 1)[-1].strip()
        elif "Battery Percentage" in s:
            m = re.search(r'\((\d+)\)', s)
            if m: dev["battery"] = int(m.group(1))
    return dev

def load_devices():
    devs = get_devices()
    for d in devs:
        enrich(d)
    return devs

def scan_nearby(duration=10):
    try:
        proc = subprocess.Popen(
            ["bluetoothctl", "scan", "on"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(duration)
        proc.terminate()
    except Exception:
        pass
    out, _ = run(["bluetoothctl", "devices"])
    found = []
    for line in out.splitlines():
        p = line.strip().split(" ", 2)
        if len(p) >= 3 and p[0] == "Device":
            found.append({"mac": p[1], "name": p[2],
                          "connected": False, "paired": False,
                          "trusted": False, "battery": None, "type": "unknown"})
    return found

def do_connect(mac):
    _, rc = run(["bluetoothctl", "connect", mac], timeout=15)
    return rc == 0

def do_disconnect(mac):
    _, rc = run(["bluetoothctl", "disconnect", mac])
    return rc == 0

def do_pair(mac):
    _, rc = run(["bluetoothctl", "pair", mac], timeout=20)
    return rc == 0

def do_trust(mac):    run(["bluetoothctl", "trust",   mac])
def do_untrust(mac):  run(["bluetoothctl", "untrust", mac])
def do_remove(mac):
    _, rc = run(["bluetoothctl", "remove", mac])
    return rc == 0

def do_rename(mac, name):
    run(["bluetoothctl", "system-alias", mac, name])

# ── audio profiles ────────────────────────────────────────────────

def get_bt_card(mac):
    card_name = "bluez_card." + mac.replace(":", "_")
    out, _    = run(["pactl", "list", "cards", "short"])
    for line in out.splitlines():
        if mac.replace(":", "_") in line or card_name in line:
            return line.split()[1] if len(line.split()) > 1 else card_name
    return card_name

def get_audio_profiles(mac):
    card  = get_bt_card(mac)
    out, _ = run(["pactl", "list", "cards"])
    profiles = []
    in_card  = False
    in_profs = False
    active   = None
    for line in out.splitlines():
        if mac.replace(":", "_") in line or card in line:
            in_card = True
        if in_card and "Active Profile:" in line:
            active = line.split(":", 1)[-1].strip()
        if in_card and "Profiles:" in line:
            in_profs = True
            continue
        if in_profs:
            if line.startswith("\t\t"):
                name = line.strip().split(":")[0].strip()
                if name and name != "off":
                    profiles.append(name)
            elif line.startswith("\t") and not line.startswith("\t\t"):
                in_profs = False
    return profiles, active, card

def set_audio_profile(card, profile):
    _, rc = run(["pactl", "set-card-profile", card, profile])
    return rc == 0

# ── headsetcontrol ────────────────────────────────────────────────

def hsc_battery():
    try:
        r = subprocess.run(["headsetcontrol", "-b", "-o", "json"],
                           capture_output=True, text=True, timeout=5)
        if r.returncode != 0: return None
        data  = json.loads(r.stdout)
        devs  = data.get("devices", [])
        if not devs: return None
        batt  = devs[0].get("battery", {})
        result = {k: batt[k] for k in ("left", "right", "case", "level") if batt.get(k) is not None}
        return result or None
    except Exception:
        return None

# ── visual ────────────────────────────────────────────────────────

def type_icon(t):
    t = (t or "").lower()
    if any(x in t for x in ("headset", "headphone", "audio")): return "󰋋"
    if "phone"    in t: return "󰄜"
    if "computer" in t: return "󰌢"
    if "keyboard" in t: return "󰌌"
    if "mouse"    in t: return "󰍽"
    if "joystick" in t: return "󰺵"
    if "speaker"  in t: return "󰓃"
    return "󰂯"

def batt_bar(pct):
    if pct is None: return "[dim]── no data ──[/dim]"
    filled = round(pct / 10)
    color  = "green" if pct > 50 else ("yellow" if pct > 20 else "red")
    return f"[{color}]{'█' * filled}[/{color}][dim]{'░' * (10 - filled)}[/dim]  [{color}]{pct}%[/{color}]"

