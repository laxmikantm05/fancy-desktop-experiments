class RenameModal(ModalScreen):
    CSS = MODAL_CSS
    def __init__(self, dev):
        super().__init__()
        self.dev = dev
    def compose(self):
        with Container(classes="modal-box"):
            yield Label("  rename device", classes="modal-title")
            yield Label(f"  {self.dev['name']}", classes="modal-sub")
            yield Input(placeholder="  new name...", value=self.dev["name"], id="inp")
            yield Label("  [Enter] confirm   [Esc] cancel", classes="modal-hint")
    def on_mount(self): self.query_one("#inp", Input).focus()
    @on(Input.Submitted)
    def submitted(self, e): self.dismiss(e.value.strip() or None)
    def on_key(self, e):
        if e.key == "escape": self.dismiss(None)

class AudioProfileModal(ModalScreen):
    CSS = MODAL_CSS + """
    ListView { height: 10; background: #0d0d1a; border: solid #1a1a3a; margin-bottom: 1; }
    ListItem { height: 2; background: #0d0d1a; border-bottom: solid #0f0f1f; }
    ListView:focus > ListItem.--highlight { background: #005f7f; border-left: tall #ff2d5a; }
    ListView:focus > ListItem.--highlight Label { color: #00eeff; text-style: bold; }
    """
    def __init__(self, profiles, active):
        super().__init__()
        self.profiles = profiles
        self.active   = active
    def compose(self):
        with Container(classes="modal-box"):
            yield Label("  audio profile", classes="modal-title")
            yield Label(f"  active: {self.active or 'unknown'}", classes="modal-sub")
            lv = ListView(id="prof-list")
            yield lv
            yield Label("  [Enter] select   [Esc] cancel", classes="modal-hint")
    def on_mount(self):
        lv = self.query_one("#prof-list", ListView)
        for p in self.profiles:
            marker = "  [green]◉[/green]  " if p == self.active else "     "
            lv.append(ListItem(Label(f"{marker}{p}", markup=True)))
        lv.focus()
    @on(ListView.Selected)
    def selected(self, e):
        idx = e.list_view.index
        if idx is not None and idx < len(self.profiles):
            self.dismiss(self.profiles[idx])
    def on_key(self, e):
        if e.key == "escape": self.dismiss(None)

