#!/usr/bin/env python3
"""
wifi  --  nmcli wifi TUI  (urwid edition)
install:  sudo cp wifi /usr/local/bin/ && sudo chmod +x /usr/local/bin/wifi
deps:     pip install urwid --break-system-packages
          nmcli (part of NetworkManager, usually pre-installed)
"""
import sys, os, subprocess, threading, time, shutil

if "--help" in sys.argv:
    print("""wifi  --  nmcli wifi TUI
  /        scan / search     Enter  connect
  d        disconnect        r      rescan
  f        forget network    i      network info
  Tab      cycle panels      q      quit
"""); sys.exit(0)

missing = []
if not shutil.which("nmcli"):
    missing.append("nmcli  (sudo dnf install NetworkManager / sudo apt install network-manager)")
try:    import urwid
except: missing.append("urwid  (pip install urwid --break-system-packages)")
if missing:
    print("\n  missing:\n" + "\n".join(f"    {m}" for m in missing)); sys.exit(1)

import urwid

