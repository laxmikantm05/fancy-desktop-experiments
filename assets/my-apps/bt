# ─── bluetoothctl helpers ─────────────────────────────────────────────────────
def _run(*args, timeout=10):
    try:
        r = subprocess.run(list(args), capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip(), r.returncode
    except Exception as e:
        return str(e), 1

def _btctl(*cmds, timeout=15):
    """Send commands to bluetoothctl via echo pipe."""
    joined = "\n".join(cmds)
    try:
        r = subprocess.run(
            ["bluetoothctl"],
            input=joined + "\n",
            capture_output=True, text=True, timeout=timeout
        )
        return r.stdout + r.stderr, r.returncode
    except Exception as e:
        return str(e), 1

def bt_enabled():
    out, _ = _run("bluetoothctl", "show")
    for line in out.splitlines():
        if "Powered:" in line:
            return "yes" in line.lower()
    return False

def toggle_bt():
    if bt_enabled():
        _btctl("power off")
    else:
        _btctl("power on")

def get_devices():
    """Return paired + cached devices, annotated with connection status."""
    devices = {}

    out, _ = _run("bluetoothctl", "devices", "Paired")
    for line in out.splitlines():
        m = re.match(r"Device ([0-9A-F:]+)\s+(.+)", line.strip(), re.IGNORECASE)
        if m:
            mac, name = m.group(1).upper(), m.group(2).strip()
            devices[mac] = {"mac": mac, "name": name, "paired": True,
                            "connected": False, "trusted": False, "rssi": ""}

    out, _ = _run("bluetoothctl", "devices")
    for line in out.splitlines():
        m = re.match(r"Device ([0-9A-F:]+)\s+(.+)", line.strip(), re.IGNORECASE)
        if m:
            mac, name = m.group(1).upper(), m.group(2).strip()
            if mac not in devices:
                devices[mac] = {"mac": mac, "name": name, "paired": False,
                                "connected": False, "trusted": False, "rssi": ""}

    for mac, dev in list(devices.items()):
        out, _ = _run("bluetoothctl", "info", mac)
        for line in out.splitlines():
            l = line.strip()
            if l.startswith("Connected:"):
                dev["connected"] = "yes" in l.lower()
            elif l.startswith("Trusted:"):
                dev["trusted"] = "yes" in l.lower()
            elif l.startswith("RSSI:"):
                dev["rssi"] = l.split(":", 1)[-1].strip()
            elif l.startswith("Alias:") and not dev["name"]:
                dev["name"] = l.split(":", 1)[-1].strip()

    result = sorted(devices.values(),
                    key=lambda d: (not d["connected"], not d["paired"], d["name"].lower()))
    return result

def start_scan():
    def _scan():
        _btctl("scan on", timeout=32)
        _btctl("scan off")
    threading.Thread(target=_scan, daemon=True).start()

def connect_device(mac):
    out, rc = _btctl(f"connect {mac}", timeout=20)
    return rc == 0 or "successful" in out.lower(), out

def disconnect_device(mac):
    out, rc = _btctl(f"disconnect {mac}", timeout=10)
    return rc == 0 or "successful" in out.lower(), out

def trust_device(mac):
    out, rc = _btctl(f"trust {mac}", timeout=10)
    return rc == 0, out

def untrust_device(mac):
    out, rc = _btctl(f"untrust {mac}", timeout=10)
    return rc == 0, out

def remove_device(mac):
    out, rc = _btctl(f"remove {mac}", timeout=10)
    return rc == 0, out


# ─── interactive pairing via pexpect ──────────────────────────────────────────
# Pairing agent events — sent from background thread to UI thread via pipe
class PairEvent:
    """Base class for pairing events."""

class PairConfirmEvent(PairEvent):
    """Device asks: confirm passkey XXXXXX (yes/no)?"""
    def __init__(self, passkey): self.passkey = passkey

class PairPinEvent(PairEvent):
    """Device asks: enter PIN code."""

class PairDoneEvent(PairEvent):
    """Pairing finished."""
    def __init__(self, ok, msg):
        self.ok  = ok
        self.msg = msg


def pair_interactive(mac, on_event, timeout=40):
    """
    Spawn bluetoothctl interactively, drive pairing, and call on_event()
    for each UI-relevant event.

    on_event is called from the background thread — callers must be
    thread-safe (write to a pipe, never touch urwid widgets directly).
    """
    try:
        child = pexpect.spawn("bluetoothctl", encoding="utf-8",
                              timeout=timeout, echo=False)
        child.expect(r"\[bluetooth\].*#", timeout=10)

        child.sendline(f"pair {mac}")

        patterns = [
            r"Confirm passkey (\d+)",          # 0 – SSP confirm
            r"\[agent\] Confirm passkey (\d+)", # 1 – SSP confirm (alt fmt)
            r"\[agent\] Enter.*[Pp][Ii][Nn]",   # 2 – legacy PIN request
            r"Pairing successful",              # 3 – success
            r"Failed to pair",                  # 4 – failure
            r"already paired",                  # 5 – already done
            pexpect.EOF,                        # 6
            pexpect.TIMEOUT,                    # 7
        ]

        while True:
            idx = child.expect(patterns, timeout=timeout)

            if idx in (0, 1):
                passkey = child.match.group(1)
                on_event(PairConfirmEvent(passkey))
                # Wait for the UI to call child.sendline("yes") or ("no")
                # We block here; the UI thread sends via child reference
                # returned from this call — so we expose child.
                # Actually: we wait for the next prompt after the UI responds.
                idx2 = child.expect([
                    r"Pairing successful",
                    r"Failed to pair",
                    pexpect.EOF,
                    pexpect.TIMEOUT,
                ], timeout=timeout)
                ok  = idx2 == 0
                msg = "paired successfully" if ok else "pairing failed"
                on_event(PairDoneEvent(ok, msg))
                break

            elif idx == 2:
                on_event(PairPinEvent())
                idx2 = child.expect([
                    r"Pairing successful",
                    r"Failed to pair",
                    pexpect.EOF,
                    pexpect.TIMEOUT,
                ], timeout=timeout)
                ok  = idx2 == 0
                msg = "paired successfully" if ok else "pairing failed"
                on_event(PairDoneEvent(ok, msg))
                break

            elif idx == 3:
                on_event(PairDoneEvent(True,  "paired successfully"))
                break

            elif idx in (4, 6, 7):
                on_event(PairDoneEvent(False, "pairing failed"))
                break

            elif idx == 5:
                on_event(PairDoneEvent(True, "already paired"))
                break

        try:
            child.sendline("quit")
            child.close()
        except Exception:
            pass

        return child   # caller doesn't usually need this

    except Exception as e:
        on_event(PairDoneEvent(False, str(e)[:60]))


# ─── pairing dialogs ──────────────────────────────────────────────────────────

class ConfirmDialog(urwid.WidgetWrap):
    """Show a passkey and ask the user to confirm yes/no."""
    def __init__(self, device_name, passkey, on_yes, on_no):
        self._on_yes = on_yes
        self._on_no  = on_no

        title   = urwid.Text([("title", " pair "), ("white", device_name)])
        div     = urwid.AttrMap(urwid.Divider("─"), "border")

        label   = urwid.Text(("dim",  "  confirm this passkey on both devices:"))
        code    = urwid.Text(("code", f"  {passkey}"), align="center")
        spacer  = urwid.Text("")

        btn_yes = urwid.Button("  Yes — confirm  ")
        btn_no  = urwid.Button("  No  — reject   ")
        urwid.connect_signal(btn_yes, "click", lambda _: self._on_yes())
        urwid.connect_signal(btn_no,  "click", lambda _: self._on_no())
        btn_yes_am = urwid.AttrMap(btn_yes, "input", "focus")
        btn_no_am  = urwid.AttrMap(btn_no,  "input", "focus")

        hint = urwid.Text(("hint", "  Enter/Y  confirm   N/Esc  reject"))

        pile = urwid.Pile([
            title, div, spacer,
            label, spacer, code, spacer,
            btn_yes_am, btn_no_am,
            div, hint,
        ])
        pile.focus_position = 7   # start focus on Yes button

        box    = urwid.LineBox(pile, tl_corner="┌", tr_corner="┐",
                               bl_corner="└", br_corner="┘",
                               left_side="│", right_side="│",
                               top_line="─", bottom_line="─")
        box_am = urwid.AttrMap(box, "border")
        pad    = urwid.Padding(box_am, left=6, right=6)
        filler = urwid.Filler(pad, valign="middle")
        super().__init__(filler)

    def keypress(self, size, key):
        if key in ("y", "Y", "enter"):
            self._on_yes(); return None
        if key in ("n", "N", "esc"):
            self._on_no();  return None
        return self._w.keypress(size, key)


class PinDialog(urwid.WidgetWrap):
    """Prompt the user to type a legacy PIN."""
    def __init__(self, device_name, on_submit, on_cancel):
        self._on_submit = on_submit
        self._on_cancel = on_cancel

        self._edit = urwid.Edit(caption=("dim", "  PIN: "))
        edit_am    = urwid.AttrMap(self._edit, "input", "input_focus")

        title  = urwid.Text([("title", " pair "), ("white", device_name)])
        div    = urwid.AttrMap(urwid.Divider("─"), "border")
        label  = urwid.Text(("dim", "  enter the PIN shown on the device:"))
        spacer = urwid.Text("")
        hint   = urwid.Text(("hint", "  Enter  confirm   Esc  cancel"))

        pile = urwid.Pile([title, div, label, spacer, edit_am, div, hint])
        box  = urwid.LineBox(pile, tl_corner="┌", tr_corner="┐",
                             bl_corner="└", br_corner="┘",
                             left_side="│", right_side="│",
                             top_line="─", bottom_line="─")
        box_am = urwid.AttrMap(box, "border")
        pad    = urwid.Padding(box_am, left=6, right=6)
        filler = urwid.Filler(pad, valign="middle")
        super().__init__(filler)

    def keypress(self, size, key):
        if key == "enter":
            self._on_submit(self._edit.edit_text.strip()); return None
        if key == "esc":
            self._on_cancel(); return None
        return self._w.keypress(size, key)


# ─── selectable row ───────────────────────────────────────────────────────────
class SelectableRow(urwid.WidgetWrap):
    def __init__(self, markup_normal, markup_focused=None, focus_map="focus"):
        self._markup_normal  = markup_normal
        self._markup_focused = markup_focused if markup_focused is not None else markup_normal
        self._text   = urwid.Text(markup_normal, wrap="clip")
        self._mapped = urwid.AttrMap(self._text, None, focus_map)
        super().__init__(self._mapped)

    def render(self, size, focus=False):
        self._text.set_text(self._markup_focused if focus else self._markup_normal)
        return super().render(size, focus)

    def selectable(self): return True
    def keypress(self, size, key): return key


# ─── search edit ──────────────────────────────────────────────────────────────
class SearchEdit(urwid.Edit):
    def __init__(self, on_change, on_submit):
        super().__init__(caption=("dim", "  filter: "))
        self._on_change  = on_change
        self._on_submit  = on_submit

    def keypress(self, size, key):
        if key == "enter":
            self._on_submit(self.edit_text.strip())
            return None
        r = super().keypress(size, key)
        self._on_change(self.edit_text)
        return r


