C1="[reverse] / [/reverse]Search  [reverse]Enter[/reverse]Play  [reverse]Spc[/reverse]Pause  [reverse] N [/reverse]Next  [reverse] P [/reverse]Prev  [reverse] , [/reverse]-5s  [reverse] . [/reverse]+5s"
C2="[reverse] A [/reverse]Queue  [reverse] D [/reverse]Download  [reverse] L [/reverse]Liked  [reverse] O [/reverse]Local  [reverse] C [/reverse]Clear  [reverse]+/-[/reverse]Vol  [reverse] Q [/reverse]Quit"

NAV=[("search"," [/] Search"),("liked"," [L] Liked"),("local"," [O] Local")]

class MusicApp(App):
    CSS=CSS
    BINDINGS=[
        Binding("/",        "fs",    ""),Binding("s","fs","",show=False),
        Binding("enter",    "play",  "",show=False),
        Binding("space",    "pause", ""),Binding("n","nxt",""),Binding("p","prv",""),
        Binding("comma",    "sb",    ""),Binding("full_stop","sf",""),
        Binding("a","addq",""),Binding("d","dl",""),Binding("c","clr",""),
        Binding("l","lib",""),Binding("o","local",""),
        Binding("+","vup",""),Binding("-","vdn",""),Binding("q","quit",""),
    ]

    def __init__(self):
        super().__init__()
        self._res=[]; self._q=[]; self._qi=-1; self._now=None; self._view="search"

    def compose(self)->ComposeResult:
        with Horizontal(id="topbar"):
            yield Label(" ytmusic",id="logo")
            yield Input(placeholder=" search songs...",id="search-input")
            yield Label("songs",id="filter-lbl")
        with Horizontal(id="body"):
            with Vertical(id="sidebar"):
                yield Label(" library",id="sb-hdr")
                yield ListView(id="sidebar-list")
            with Vertical(id="main"):
                yield Label("",id="main-hdr")
                yield ListView(id="results-list")
            with Vertical(id="right-panel"):
                yield Static("",id="now-box",markup=False)
                yield Label("",id="queue-hdr")
                yield ListView(id="queue-list")
        with Vertical(id="player"):
            with Horizontal(id="p-row1"):
                yield Static("  nothing playing",id="p-title", markup=False)
                yield Static("  --  ",           id="p-state", markup=False)
                yield Static(f"vol {MPV.volume}%",id="p-vol",  markup=False)
            with Horizontal(id="p-row2"):
                yield Static("00:00",             id="p-time-l",markup=False)
                yield Static("["+"-"*36+"]",      id="p-bar",   markup=False)
                yield Static("00:00",             id="p-time-r",markup=False)
            yield Static("",id="p-status",markup=False)
        yield Label(C2,id="ctrl2")
        yield Label(C1,id="ctrl1")

    def on_mount(self):
        lv=self.query_one("#sidebar-list",ListView)
        for _,label in NAV: lv.append(ListItem(Label(label,markup=False)))
        self._upd_hdr()
        try: self.query_one("#search-input",Input).focus()
        except: pass
        self.set_interval(1,self._tick)

    def _tick(self):
        if not MPV.alive() and self._now and not MPV.paused:
            if self._qi<len(self._q)-1:
                self._qi+=1; self._play(self._q[self._qi])
        self._draw_pb()

    def _upd_hdr(self):
        n=len(self._res)
        lbl={"search":f"results ({n})","liked":f"liked ({n})","local":f"files ({n})"}.get(self._view,"")
        self.query_one("#main-hdr",Label).update(f"  #    title{' '*28}artist{' '*14}time    [{lbl}]")
        self.query_one("#queue-hdr",Label).update(f" queue ({len(self._q)})")

    def _draw_now(self):
        w=self.query_one("#now-box",Static); t=self._now
        if not t: w.update(" now playing\n\n  --\n\n  search + Enter"); return
        st="|> playing" if MPV.alive() and not MPV.paused else "|| paused"
        w.update(f" now playing\n\n  {t['title'][:22]}\n  {t['artist'][:22]}\n\n  {st}")

    def _draw_pb(self):
        t=self._now; pos=MPV.pos(); dur=MPV.dur()
        icon=" |> " if MPV.alive() and not MPV.paused else " || "
        if not t:
            self.query_one("#p-title",Static).update("  nothing playing")
            self.query_one("#p-state",Static).update("  --  ")
        else:
            self.query_one("#p-title",Static).update(f"  {t['title'][:44]}  --  {t['artist'][:22]}")
            self.query_one("#p-state",Static).update(icon)
        self.query_one("#p-vol",   Static).update(f"vol {MPV.volume}%")
        self.query_one("#p-time-l",Static).update(fmt(pos))
        self.query_one("#p-bar",   Static).update("["+pbar(pos,dur,36)+"]")
        self.query_one("#p-time-r",Static).update(fmt(dur))

    def _rebuild(self):
        lv=self.query_one("#results-list",ListView); lv.clear(); self._upd_hdr()
        for i,t in enumerate(self._res):
            pre=">" if self._now and self._now["id"]==t["id"] else " "
            row=f" {pre} {i+1:>3}  {t['title'][:34]:<34}  {t['artist'][:20]:<20}  {t['duration'][:5]}"
            lv.append(ListItem(Label(row,markup=False)))

    def _rebuild_q(self):
        lv=self.query_one("#queue-list",ListView); lv.clear(); self._upd_hdr()
        for i,t in enumerate(self._q):
            pre=">" if i==self._qi else " "
            lv.append(ListItem(Label(f" {pre} {t['title'][:20]}",markup=False)))

    def _st(self,msg): self.query_one("#p-status",Static).update(f"  {msg}")

    def _play(self,track):
        self._now=track; self._draw_now(); self._draw_pb(); self._rebuild(); self._rebuild_q()
        self._st(f"loading: {track['title'][:40]}...")
        if track["source"]=="local": MPV.play(track["id"]); self._draw_now(); self._draw_pb()
        else: self._stream(track)

    @work(thread=True)
    def _stream(self,track):
        url=stream_url(track["id"])
        if not url: self.app.call_from_thread(self._st,"stream failed"); return
        MPV.play(url)
        self.app.call_from_thread(self._draw_now)
        self.app.call_from_thread(self._st,f"{track['title'][:40]}")

    def action_fs(self):
        try: self.query_one("#search-input",Input).focus()
        except: pass

    def action_play(self):
        try:
            si=self.query_one("#search-input",Input)
            if si.has_focus:
                q=si.value.strip()
                if q: self._search(q)
                return
        except: pass
        lv=self.query_one("#results-list",ListView); idx=lv.index
        if idx is None or idx>=len(self._res): return
        t=self._res[idx]; self._q.append(t); self._qi=len(self._q)-1; self._play(t)

    @work(thread=True)
    def _search(self,q):
        self.app.call_from_thread(self._st,f"searching: {q[:30]}...")
        results=search_ytm(q)
        if not results: self.app.call_from_thread(self._st,f"no results: {q[:30]}"); return
        self._res=results; self._view="search"
        self.app.call_from_thread(self._rebuild)
        self.app.call_from_thread(self._st,f"{len(results)} results")
        self.app.call_from_thread(self.query_one("#results-list").focus)

    def action_pause(self):
        if not self._now: return
        MPV.toggle_pause(); self._draw_now(); self._draw_pb()

    def action_nxt(self):
        if self._qi<len(self._q)-1: self._qi+=1; self._play(self._q[self._qi])

    def action_prv(self):
        if self._qi>0: self._qi-=1; self._play(self._q[self._qi])

    def action_sb(self):
        if MPV.alive(): MPV.seek(-5)

    def action_sf(self):
        if MPV.alive(): MPV.seek(5)

    def action_addq(self):
        lv=self.query_one("#results-list",ListView); idx=lv.index
        if idx is None or idx>=len(self._res): return
        t=self._res[idx]; self._q.append(t); self._rebuild_q()
        self._st(f"queued: {t['title'][:30]}")

    @work(thread=True)
    def action_dl(self):
        lv=self.query_one("#results-list",ListView); idx=lv.index
        if idx is None or idx>=len(self._res): return
        t=self._res[idx]
        if t["source"]!="online": self.app.call_from_thread(self._st,"already local"); return
        self.app.call_from_thread(self._st,f"downloading {t['title'][:30]}...")
        ok,path=dl_track(t["id"],t["title"])
        self.app.call_from_thread(self._st,f"saved to {path}" if ok else "download failed")

    def action_clr(self):
        MPV.stop(); self._q=[]; self._qi=-1; self._now=None
        self._rebuild(); self._rebuild_q(); self._draw_now(); self._draw_pb()

    @work(thread=True)
    def action_lib(self):
        if not AUTH.exists(): self.app.call_from_thread(self._st,"run: music --setup"); return
        self.app.call_from_thread(self._st,"loading liked songs...")
        tracks=get_liked()
        if not tracks: self.app.call_from_thread(self._st,"no liked songs found"); return
        self._res=tracks; self._view="liked"
        self.app.call_from_thread(self._rebuild)
        self.app.call_from_thread(self._st,f"{len(tracks)} liked songs")
        self.app.call_from_thread(self.query_one("#results-list").focus)

    @work(thread=True)
    def action_local(self):
        folder=str(pathlib.Path.home()/"Music")
        if not os.path.isdir(folder): self.app.call_from_thread(self._st,"~/Music not found"); return
        self.app.call_from_thread(self._st,"scanning local files...")
        tracks=scan_local(folder); self._res=tracks; self._view="local"
        self.app.call_from_thread(self._rebuild)
        self.app.call_from_thread(self._st,f"{len(tracks)} local files")
        self.app.call_from_thread(self.query_one("#results-list").focus)

    def action_vup(self): MPV.set_vol(MPV.volume+5);  self._draw_pb()
    def action_vdn(self): MPV.set_vol(MPV.volume-5);  self._draw_pb()
    def action_quit(self): MPV.cleanup(); self.exit()

    @on(Input.Submitted,"#search-input")
    def on_search(self,e):
        q=e.value.strip()
        if q: self._search(q)

    @on(ListView.Selected,"#results-list")
    def on_res(self,e): self.action_play()

    @on(ListView.Selected,"#queue-list")
    def on_qsel(self,e):
        idx=e.list_view.index
        if idx is not None and idx<len(self._q): self._qi=idx; self._play(self._q[idx])

    @on(ListView.Selected,"#sidebar-list")
    def on_sb(self,e):
        idx=e.list_view.index
        if idx is None or idx>=len(NAV): return
        key=NAV[idx][0]
        if key=="search": self.action_fs()
        elif key=="liked": self.action_lib()
        elif key=="local": self.action_local()

if __name__=="__main__":
    try: MusicApp().run()
    finally: MPV.cleanup()

